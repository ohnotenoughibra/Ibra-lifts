# Vercel Postgres (automatically set when you add a Postgres database in Vercel dashboard)
# These are auto-populated by Vercel - you don't need to set them manually
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# App URL (for production — auto-detected on Vercel if not set)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Whoop Integration (get these from https://developer-dashboard.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
