# Vercel Postgres (automatically set when you add a Postgres database in Vercel dashboard)
# These are auto-populated by Vercel - you don't need to set them manually
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# App URL (for production — auto-detected on Vercel if not set)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# NextAuth / Auth.js — generate with: npx auth secret
AUTH_SECRET=

# Resend (for password reset emails) — get key from https://resend.com
RESEND_API_KEY=
# Optional: custom from address (requires verified domain on Resend)
# RESEND_FROM_EMAIL=Roots Gains <noreply@yourdomain.com>

# Whoop Integration (get these from https://developer-dashboard.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
