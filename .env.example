# Vercel Postgres (automatically set when you add a Postgres database in Vercel dashboard)
# These are auto-populated by Vercel - you don't need to set them manually
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# App URL (for production — auto-detected on Vercel if not set)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# NextAuth / Auth.js — generate with: npx auth secret
AUTH_SECRET=

# Google OAuth (get these from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth (get these from https://developer.apple.com)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Resend (for password reset emails) — get key from https://resend.com
RESEND_API_KEY=
# Optional: custom from address (requires verified domain on Resend)
# RESEND_FROM_EMAIL=Roots Gains <noreply@yourdomain.com>

# Whoop Integration (get these from https://developer-dashboard.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Token encryption key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=

# PayPal Subscriptions (get these from https://developer.paypal.com)
# Supports PayPal checkout + SEPA Lastschrift for EU customers
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Set to 'sandbox' for development, 'live' for production
PAYPAL_MODE=sandbox

# PayPal Webhook verification (get from PayPal developer dashboard)
PAYPAL_WEBHOOK_ID=
# PayPal API URL ('https://api-m.sandbox.paypal.com' for dev, 'https://api-m.paypal.com' for production)
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
# PayPal Plan IDs (create subscription plans in PayPal dashboard)
NEXT_PUBLIC_PAYPAL_PLAN_MONTHLY=
NEXT_PUBLIC_PAYPAL_PLAN_ANNUAL=

# Sentry Error Tracking (get DSN from https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
# Optional: auth token for source map uploads in CI/CD
# SENTRY_AUTH_TOKEN=
