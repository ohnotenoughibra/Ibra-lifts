# Vercel Postgres (automatically set when you add a Postgres database in Vercel dashboard)
# These are auto-populated by Vercel - you don't need to set them manually
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# App URL (for production)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
